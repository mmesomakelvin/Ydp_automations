# Supabase connection for YDP Mentorship Hub.
# Copy this file to `.env.local` and fill in the values from your Supabase
# project: Project Settings → API.

# Project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Public anon key (safe to expose in the browser; RLS protects the data).
VITE_SUPABASE_ANON_KEY=
